# Leave blank for local dev (the Vite proxy forwards /api to localhost:3001).
# In production (Render Static Site) set this to your ProjectPortalApi URL:
# VITE_API_URL=https://projectportal-api.onrender.com
VITE_API_URL=

# Password shown + autofilled by the demo-login buttons on the sign-in screen.
# Set this to match the API's SEED_PASSWORD so the buttons log in cleanly.
# Defaults to Password123 if blank. (Compiled in at build time.)
VITE_DEMO_PASSWORD=
